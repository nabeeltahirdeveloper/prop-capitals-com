# Flat node_modules (npm/yarn-like) for runtime compatibility with Prisma,
# NestJS and ts-node, which assume a hoisted layout.
node-linker=hoisted

# Run pre/post lifecycle scripts (e.g. backend "prebuild" -> prisma generate).
enable-pre-post-scripts=true

# Don't fail the install on peer-dependency mismatches (npm/yarn were lenient).
strict-peer-dependencies=false
